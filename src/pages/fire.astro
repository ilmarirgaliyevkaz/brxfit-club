---
import AdLandingLayout from "../layouts/AdLandingLayout.astro";
import WhatsAppButton from "../components/ui/WhatsAppButton.astro";
import { Flame, Dumbbell, Wind, Activity, MapPin, Instagram } from "lucide-astro";
import { locations, TWO_GIS, INSTAGRAM_URL } from "../data/site";

const FIRE_MSG =
  "Заявка с сайта brxfit.club (Fire). Здравствуйте! Хочу 3 пробных занятия за 2990 ₸ (Fire, фитнес-бокс).";

const club = locations[0];

const marquee = [
  "до 1000 ккал", "кардио + сила", "любой уровень",
  "без спаррингов", "бокс как тренировка",
];

const benefits = [
  { icon: Flame, title: "Жиросжигание", text: "Высокий пульс всю тренировку — до 1000 ккал за час. Быстрее обычного кардио." },
  { icon: Dumbbell, title: "Сила и тонус", text: "Работа всем телом: руки, кор, ноги. Подтянутая форма без перекачки." },
  { icon: Wind, title: "Снятие стресса", text: "Удары по мешку забирают напряжение. Выходишь — голова чистая." },
  { icon: Activity, title: "Координация и реакция", text: "Боксёрские связки развивают скорость, координацию и реакцию." },
];

const audience = [
  { title: "Сбросить вес", text: "Жиросжигающий формат — основная цель тренировок." },
  { title: "Подтянуть тело", text: "Тонус и форма без изматывающего тренажёрного зала." },
  { title: "Снять стресс", text: "Выплеснуть напряжение и зарядиться энергией после работы." },
];

const approach = [
  "Нагрузка серьёзная, но дозируется — входишь в свой темп.",
  "Без спаррингов — это тренировка, а не бои.",
  "Тренер ставит технику ударов, чтобы ты не получил травму.",
];

const steps = [
  { n: "01", title: "Напишите в WhatsApp", text: "Одно сообщение — меньше минуты." },
  { n: "02", title: "Мы ответим", text: "Подберём удобное время." },
  { n: "03", title: "Пробная тренировка", text: "Приходите, пробуете нагрузку. Решение — за вами." },
];

const faq = [
  { q: "Нужна ли подготовка?", a: "Нет. Берём с нуля — нагрузка подстраивается под твой уровень." },
  { q: "Для кого это?", a: "Фитнес-бокс для всех — мужчины и женщины, любой уровень." },
  { q: "Будут спарринги?", a: "Нет. Фитнес-бокс — это тренировка без спаррингов." },
  { q: "Сколько калорий сжигается?", a: "До 1000 ккал за тренировку — зависит от интенсивности и веса." },
  { q: "Сколько стоит?", a: "Первые 3 занятия — 2990 ₸. Дальше подберём формат при записи." },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Фитнес-бокс",
  provider: {
    "@type": "SportsActivityLocation",
    name: "Bronx Fitness",
    areaServed: "Астана, KZ",
  },
  audience: { "@type": "PeopleAudience", suggestedMinAge: 16 },
  areaServed: "Астана",
  url: "https://brxfit.club/fire",
};
---

<AdLandingLayout
  title="Фитнес-бокс в Астане — Bronx Fire | 3 пробных за 2990 ₸"
  description="Фитнес-бокс в Bronx: жиросжигающие тренировки на боксёрской технике. Кардио, сила, координация, до 1000 ккал за тренировку, без спаррингов. Любой уровень. Первые 3 занятия — 2990 ₸."
  ogImage="/og-fire.png"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative flex min-h-[80vh] items-center overflow-hidden bg-bg">
    <div class="relative mx-auto w-full max-w-7xl px-6 py-24">
      <p class="eyebrow">Фитнес-бокс · Астана</p>
      <h1 class="mt-4 max-w-4xl text-5xl font-extrabold uppercase leading-[0.95] tracking-tight md:text-7xl">
        Фитнес-бокс, который приводит в <span class="text-gold">форму</span>
      </h1>
      <p class="mt-6 max-w-xl text-base leading-relaxed text-muted md:text-lg">
        Высокоинтенсивные тренировки на боксёрской технике: кардио, сила,
        координация. До 1000 ккал за тренировку, без спаррингов. Для всех — и
        мужчин, и женщин.
      </p>
      <div class="mt-8">
        <WhatsAppButton label="3 занятия за 2990 ₸" message={FIRE_MSG} />
      </div>
    </div>
  </section>

  <!-- Marquee -->
  <section class="bg-bg">
    <div class="overflow-hidden border-y border-line bg-surface py-3" aria-hidden="true">
      <div class="flex w-max animate-marquee whitespace-nowrap">
        {
          [...marquee, ...marquee].map((t) => (
            <span class="flex items-center">
              <span class="px-6 text-sm font-semibold uppercase tracking-[0.15em] text-muted">
                {t}
              </span>
              <span class="text-gold">/</span>
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <p class="eyebrow">Знакомо?</p>
    <div class="mt-6 space-y-3 text-2xl font-extrabold leading-snug md:text-3xl">
      <p>Тренажёрный зал наскучил, а результата нет?</p>
      <p>Хочешь сбросить и подтянуться, но без скучных дорожек?</p>
      <p>Нужен заряд и выход энергии после работы?</p>
    </div>
  </section>

  <!-- What it is -->
  <section class="border-t border-line bg-surface">
    <div class="mx-auto max-w-3xl px-6 py-16 md:py-24">
      <p class="eyebrow">Фитнес-бокс в Bronx</p>
      <h2 class="mt-3 text-3xl font-extrabold uppercase tracking-tight md:text-4xl">
        Это не спарринги и не синяки
      </h2>
      <p class="mt-5 text-base leading-relaxed text-muted md:text-lg">
        Фитнес-бокс — это тренировка на основе бокса: удары по мешкам и лапам,
        кардио-связки, работа над техникой и общая физподготовка. Без спаррингов
        и без контакта «на поражение». Цель — форма, выносливость и заряд, а не
        бои.
      </p>
    </div>
  </section>

  <!-- What it gives -->
  <section class="mx-auto max-w-7xl px-6 py-16 md:py-24">
    <p class="eyebrow">Что даёт фитнес-бокс</p>
    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {
        benefits.map((b) => (
          <div class="rounded border border-line bg-surface p-6">
            <b.icon class="h-8 w-8 text-gold" aria-hidden="true" />
            <h3 class="mt-4 text-xl font-semibold uppercase tracking-wide">{b.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{b.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Who it fits -->
  <section class="border-t border-line bg-surface">
    <div class="mx-auto max-w-7xl px-6 py-16 md:py-24">
      <p class="eyebrow">Кому подойдёт</p>
      <h2 class="mt-3 text-3xl font-extrabold uppercase tracking-tight md:text-5xl">
        Берём с любого уровня
      </h2>
      <div class="mt-10 grid gap-4 md:grid-cols-3">
        {
          audience.map((a) => (
            <div class="rounded border border-line bg-bg p-8">
              <h3 class="text-2xl font-extrabold uppercase tracking-tight">{a.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-muted">{a.text}</p>
            </div>
          ))
        }
      </div>
      <p class="mt-6 text-sm text-muted">
        Берём с любого уровня — интенсивность дозируется под тебя.
      </p>
    </div>
  </section>

  <!-- Approach -->
  <section class="mx-auto max-w-7xl px-6 py-16 md:py-24">
    <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="eyebrow">Подход</p>
        <h2 class="mt-3 text-3xl font-extrabold uppercase tracking-tight md:text-4xl">
          Нагрузка — под тебя
        </h2>
      </div>
      <ul class="grid gap-4">
        {
          approach.map((a) => (
            <li class="flex gap-4 border-b border-line pb-4 text-muted">
              <span class="mt-2 h-2 w-2 shrink-0 bg-gold" />
              <span class="leading-relaxed">{a}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Trainers -->
  <section class="bg-gold text-bg">
    <div class="mx-auto max-w-7xl px-6 py-16 md:py-24">
      <p class="text-sm font-semibold uppercase tracking-[0.14em] text-bg/70">Тренеры</p>
      <p class="mt-6 text-3xl font-extrabold leading-tight md:text-5xl">
        Мастера спорта и призёры турниров
      </p>
      <p class="mt-6 max-w-prose text-lg leading-relaxed text-bg/80">
        Среди тренеров Bronx — мастера спорта Казахстана, призёры республиканских
        и международных турниров. Проведут тренировку так, чтобы ты выложился и
        не травмировался.
      </p>
    </div>
  </section>

  <!-- How to start -->
  <section class="mx-auto max-w-7xl px-6 py-16 md:py-24">
    <p class="eyebrow">Как начать</p>
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {
        steps.map((s) => (
          <div class="rounded border border-line bg-surface p-7">
            <div class="font-mono text-2xl font-bold text-gold">{s.n}</div>
            <h3 class="mt-4 text-xl font-semibold uppercase tracking-wide">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{s.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Quote -->
  <section class="border-t border-line bg-surface">
    <div class="mx-auto max-w-4xl px-6 py-16 md:py-24">
      <p class="eyebrow">Главное</p>
      <blockquote class="mt-6 text-3xl font-extrabold leading-snug md:text-5xl">
        Лучшее кардио — то, на которое хочется возвращаться.
        <span class="text-gold">Фитнес-бокс затягивает.</span>
      </blockquote>
    </div>
  </section>

  <!-- Location -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-7xl px-6 py-16 md:py-24">
      <p class="eyebrow">Где заниматься</p>
      <h2 class="mt-3 text-3xl font-extrabold uppercase tracking-tight md:text-4xl">
        {club.name}
      </h2>
      <div class="mt-8 space-y-4">
        <p class="flex items-start gap-3 text-muted">
          <MapPin class="mt-1 h-5 w-5 shrink-0 text-gold" aria-hidden="true" />
          <span>{club.address}</span>
        </p>
        <p class="text-muted">{club.hours}</p>
        <div class="flex flex-wrap gap-3 pt-2">
          <a href={club.mapUrl} target="_blank" rel="noopener" class="btn-ghost">
            Открыть на 2ГИС ({TWO_GIS.rating} ★)
          </a>
          <a href={INSTAGRAM_URL} target="_blank" rel="noopener" class="btn-ghost">
            <Instagram class="h-5 w-5" aria-hidden="true" /> Instagram
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-line bg-surface">
    <div class="mx-auto max-w-3xl px-6 py-16 md:py-24">
      <p class="eyebrow">Частые вопросы</p>
      <div class="mt-8 divide-y divide-line">
        {
          faq.map((f) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-semibold">
                {f.q}
                <span class="text-gold transition-transform group-open:rotate-45">+</span>
              </summary>
              <p class="mt-3 leading-relaxed text-muted">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-3xl px-6 py-20 text-center md:py-28">
      <p class="eyebrow">Пробная тренировка</p>
      <h2 class="mt-3 text-3xl font-extrabold uppercase leading-tight tracking-tight md:text-5xl">
        3 пробных занятия —<br /><span class="text-gold">2990 ₸</span>
      </h2>
      <p class="mx-auto mt-4 max-w-prose text-muted">
        Напиши в WhatsApp — подберём удобное время. Приходи с любой подготовкой.
      </p>
      <div class="mt-8 flex justify-center">
        <WhatsAppButton label="Написать в WhatsApp" message={FIRE_MSG} />
      </div>
    </div>
  </section>

  <WhatsAppButton slot="floating" variant="floating" message={FIRE_MSG} />
</AdLandingLayout>
