---
import AdLandingLayout from "../layouts/AdLandingLayout.astro";
import WhatsAppButton from "../components/ui/WhatsAppButton.astro";
import { Zap, ShieldCheck, Shield, Activity, Users, Target, MapPin, Instagram } from "lucide-astro";
import { locations, TWO_GIS, INSTAGRAM_URL } from "../data/site";

const TEENS_MSG =
  "Заявка с сайта brxfit.club (Teens). Здравствуйте! Хочу записать подростка на 3 пробных занятия за 2990 ₸ в Bronx (Teens, 13–17).";

const club = locations[0];

const marquee = [
  "13–17 лет", "характер", "дисциплина", "уверенность", "безопасно",
];

const benefits = [
  { icon: Zap, title: "Форма и координация", text: "Регулярная нагрузка, ловкость, выносливость — без перегруза, по возрасту." },
  { icon: ShieldCheck, title: "Уверенность в себе", text: "Подросток чувствует себя увереннее — в зале, в школе и во дворе." },
  { icon: Shield, title: "Навыки самообороны", text: "Умение защитить себя — спокойно и без агрессии. Контроль вместо драки." },
  { icon: Activity, title: "Дисциплина и характер", text: "Учится держать себя в руках и доводить начатое до конца." },
  { icon: Users, title: "Команда и режим", text: "Друзья, тренер, расписание — структура, которой часто не хватает." },
  { icon: Target, title: "Концентрация", text: "Внимание и собранность на тренировках — пригодится и в учёбе." },
];

const safety = [
  "Подростковые группы — тренируются в своём возрасте, отдельно от младших.",
  "Защитная экипировка и контроль нагрузки на каждой тренировке.",
  "Тренер всегда рядом — следит за техникой и самочувствием каждого.",
];

const steps = [
  { n: "01", title: "Напишите в WhatsApp", text: "Одно сообщение — меньше минуты." },
  { n: "02", title: "Мы ответим", text: "Подберём группу и удобное время." },
  { n: "03", title: "Пробное занятие", text: "Подросток пробует, вы смотрите. Решение — за вами." },
];

const faq = [
  { q: "С какого возраста?", a: "Направление Teens — с 13 до 17 лет. Для детей младше есть детские группы." },
  { q: "Нужна ли подготовка?", a: "Нет. Берём с нуля — тренер ставит базовую технику." },
  { q: "Это не опасно?", a: "Нагрузка дозируется по возрасту, к спаррингам подключают только по готовности, всегда в экипировке и под контролем тренера." },
  { q: "Что взять на первое занятие?", a: "Удобную спортивную одежду и сменную спортивную обувь." },
  { q: "Сколько стоит?", a: "Первые 3 занятия — 2990 ₸. Дальше подберём формат при записи." },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Бокс для подростков",
  provider: {
    "@type": "SportsActivityLocation",
    name: "Bronx Fitness",
    areaServed: "Астана, KZ",
  },
  audience: { "@type": "PeopleAudience", suggestedMinAge: 13, suggestedMaxAge: 17 },
  areaServed: "Астана",
  url: "https://brxfit.club/teens",
};
---

<AdLandingLayout
  title="Бокс для подростков в Астане — Bronx Teens | 3 пробных за 2990 ₸"
  description="Бокс для подростков 13–17 лет в Bronx: техника, дисциплина, уверенность под контролем тренера. Безопасно, по возрасту. Первые 3 занятия — 2990 ₸."
  ogImage="/og-teens.png"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="relative flex min-h-[80vh] items-center overflow-hidden bg-bg">
    <div class="relative mx-auto w-full max-w-7xl px-6 py-24">
      <p class="eyebrow">Бокс для подростков · 13–17 · Астана</p>
      <h1 class="mt-4 max-w-4xl text-5xl font-extrabold uppercase leading-[0.95] tracking-tight md:text-7xl">
        Бокс, который развивает <span class="text-gold">уверенность</span> и характер
      </h1>
      <p class="mt-6 max-w-xl text-base leading-relaxed text-muted md:text-lg">
        Для подростков 13–17 лет. Техника, координация, дисциплина — под
        контролем тренера и по возрасту. Запишите подростка на пробное.
      </p>
      <div class="mt-8">
        <WhatsAppButton label="3 занятия за 2990 ₸" message={TEENS_MSG} />
      </div>
    </div>
  </section>

  <!-- Marquee -->
  <section class="bg-bg">
    <div class="overflow-hidden border-y border-line bg-surface py-3" aria-hidden="true">
      <div class="flex w-max animate-marquee whitespace-nowrap">
        {
          [...marquee, ...marquee].map((t) => (
            <span class="flex items-center">
              <span class="px-6 text-sm font-semibold uppercase tracking-[0.15em] text-muted">
                {t}
              </span>
              <span class="text-gold">/</span>
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="mx-auto max-w-3xl px-6 py-16 md:py-24">
    <p class="eyebrow">Знакомо?</p>
    <div class="mt-6 space-y-3 text-2xl font-extrabold leading-snug md:text-3xl">
      <p>Много времени в телефоне и мало движения?</p>
      <p>Не хватает уверенности и умения постоять за себя?</p>
      <p>Энергии через край, а направить некуда?</p>
    </div>
  </section>

  <!-- What it is -->
  <section class="border-t border-line bg-surface">
    <div class="mx-auto max-w-3xl px-6 py-16 md:py-24">
      <p class="eyebrow">Бокс для подростков в Bronx</p>
      <h2 class="mt-3 text-3xl font-extrabold uppercase tracking-tight md:text-4xl">
        Это не «драки»
      </h2>
      <p class="mt-5 text-base leading-relaxed text-muted md:text-lg">
        Это спорт под контролем тренера: техника, координация, общая
        физподготовка и работа в группе. Нагрузка дозируется по возрасту, а к
        спаррингам подростков подключают только по готовности. Бокс здесь учит
        владеть собой, а не нападать.
      </p>
    </div>
  </section>

  <!-- What teen gets -->
  <section class="mx-auto max-w-7xl px-6 py-16 md:py-24">
    <p class="eyebrow">Что получает подросток</p>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        benefits.map((b) => (
          <div class="rounded border border-line bg-surface p-6">
            <b.icon class="h-8 w-8 text-gold" aria-hidden="true" />
            <h3 class="mt-4 text-xl font-semibold uppercase tracking-wide">{b.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{b.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Safety -->
  <section class="border-t border-line bg-surface">
    <div class="mx-auto max-w-7xl px-6 py-16 md:py-24">
      <div class="grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
        <div>
          <p class="eyebrow">Безопасность</p>
          <h2 class="mt-3 text-3xl font-extrabold uppercase tracking-tight md:text-4xl">
            Безопасность прежде всего
          </h2>
        </div>
        <ul class="grid gap-4">
          {
            safety.map((s) => (
              <li class="flex gap-4 border-b border-line pb-4 text-muted">
                <span class="mt-2 h-2 w-2 shrink-0 bg-gold" />
                <span class="leading-relaxed">{s}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <!-- Trainers -->
  <section class="bg-gold text-bg">
    <div class="mx-auto max-w-7xl px-6 py-16 md:py-24">
      <p class="text-sm font-semibold uppercase tracking-[0.14em] text-bg/70">Тренеры</p>
      <p class="mt-6 text-3xl font-extrabold leading-tight md:text-5xl">
        Наставники, которые находят подход
      </p>
      <p class="mt-6 max-w-prose text-lg leading-relaxed text-bg/80">
        Среди тренеров Bronx — мастера спорта Казахстана, призёры турниров. С
        подростками работают наставники с опытом — те, кто умеет найти подход и
        удержать дисциплину без давления.
      </p>
    </div>
  </section>

  <!-- How to start -->
  <section class="mx-auto max-w-7xl px-6 py-16 md:py-24">
    <p class="eyebrow">Как начать</p>
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {
        steps.map((s) => (
          <div class="rounded border border-line bg-surface p-7">
            <div class="font-mono text-2xl font-bold text-gold">{s.n}</div>
            <h3 class="mt-4 text-xl font-semibold uppercase tracking-wide">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{s.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Quote -->
  <section class="border-t border-line bg-surface">
    <div class="mx-auto max-w-4xl px-6 py-16 md:py-24">
      <p class="eyebrow">Главное</p>
      <blockquote class="mt-6 text-3xl font-extrabold leading-snug md:text-5xl">
        Здесь растят характер, а не только удар.
        <span class="text-gold">Главная победа — над собой вчерашним.</span>
      </blockquote>
    </div>
  </section>

  <!-- Location -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-7xl px-6 py-16 md:py-24">
      <p class="eyebrow">Где заниматься</p>
      <h2 class="mt-3 text-3xl font-extrabold uppercase tracking-tight md:text-4xl">
        {club.name}
      </h2>
      <div class="mt-8 space-y-4">
        <p class="flex items-start gap-3 text-muted">
          <MapPin class="mt-1 h-5 w-5 shrink-0 text-gold" aria-hidden="true" />
          <span>{club.address}</span>
        </p>
        <p class="text-muted">{club.hours}</p>
        <div class="flex flex-wrap gap-3 pt-2">
          <a href={club.mapUrl} target="_blank" rel="noopener" class="btn-ghost">
            Открыть на 2ГИС ({TWO_GIS.rating} ★)
          </a>
          <a href={INSTAGRAM_URL} target="_blank" rel="noopener" class="btn-ghost">
            <Instagram class="h-5 w-5" aria-hidden="true" /> Instagram
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-line bg-surface">
    <div class="mx-auto max-w-3xl px-6 py-16 md:py-24">
      <p class="eyebrow">Частые вопросы</p>
      <div class="mt-8 divide-y divide-line">
        {
          faq.map((f) => (
            <details class="group py-5">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-semibold">
                {f.q}
                <span class="text-gold transition-transform group-open:rotate-45">+</span>
              </summary>
              <p class="mt-3 leading-relaxed text-muted">{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="border-t border-line">
    <div class="mx-auto max-w-3xl px-6 py-20 text-center md:py-28">
      <p class="eyebrow">Пробное занятие</p>
      <h2 class="mt-3 text-3xl font-extrabold uppercase leading-tight tracking-tight md:text-5xl">
        3 пробных занятия —<br /><span class="text-gold">2990 ₸</span>
      </h2>
      <p class="mx-auto mt-4 max-w-prose text-muted">
        Напишите в WhatsApp — подберём группу по возрасту и удобное время.
      </p>
      <div class="mt-8 flex justify-center">
        <WhatsAppButton label="Написать в WhatsApp" message={TEENS_MSG} />
      </div>
    </div>
  </section>

  <WhatsAppButton slot="floating" variant="floating" message={TEENS_MSG} />
</AdLandingLayout>
