---
import { flagshipPrograms } from "../../data/programs";
import { ArrowUpRight } from "lucide-astro";
import WhatsAppButton from "../ui/WhatsAppButton.astro";

// Poster art per flagship. These are the brand cards already shipped for OG
// previews — reused here so the tiles are never empty.
// TODO(content): replace with real gym photography (people, bags, stations).
//   Real footage converts better than text posters.
const posterBySlug: Record<string, string> = {
  "bronx-fire": "/og-fire.png",
  "bronx-fight": "/og-fight.png",
  "bronx-teens": "/og-teens.png",
  hyrox: "/og-hyrox.png",
};

// Promo clip per flagship (autoplay muted loop). Missing slugs fall back to the
// OG poster in posterBySlug, so a tile is never black.
const videoBySlug: Record<string, string | undefined> = {
  hyrox: "/video/hyrox/hero.mp4",
  "bronx-fire": "/video/fire/hero.mp4",
  "bronx-fight": "/video/fight/hero.mp4",
  "bronx-teens": "/video/teens/hero.mp4",
};
---

<section id="flagships" class="mx-auto max-w-7xl px-6 py-16 md:py-24 lg:py-32">
  <p class="eyebrow">Самые любимые</p>
  <h2 class="mt-3 text-3xl font-extrabold uppercase tracking-tight md:text-5xl">
    С чего начинают
  </h2>
  <p class="mt-4 max-w-prose text-muted">
    Направления, куда приходит больше всего людей. Начни с любого — первые 3
    занятия за 2990 ₸.
  </p>

  <div class="mt-10 grid gap-5 sm:grid-cols-2">
    {
      flagshipPrograms.map((p) => {
        const Tag = p.href ? "a" : "div";
        const video = videoBySlug[p.slug];
        // Video tiles use their own frame grab (hero.jpg) as the poster;
        // posterBySlug (OG art) is the fallback only for tiles without a clip.
        const videoPoster = video?.replace(/\.mp4$/, ".jpg");
        const poster = posterBySlug[p.slug];
        return (
          <Tag
            {...(p.href ? { href: p.href } : {})}
            class:list={[
              "group relative flex min-h-[22rem] flex-col justify-end overflow-hidden rounded border border-line transition",
              p.href && "hover:border-gold",
            ]}
          >
            {video ? (
              <video
                class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
                poster={videoPoster}
                autoplay
                muted
                loop
                playsinline
              >
                <source src={video} type="video/mp4" />
              </video>
            ) : poster ? (
              <img
                src={poster}
                alt=""
                loading="lazy"
                class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
              />
            ) : (
              <div class="absolute inset-0 bg-surface" />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-bg via-bg/70 to-bg/20" />

            <div class="relative p-6">
              <div class="flex items-start justify-between gap-3">
                <h3 class="text-2xl font-extrabold uppercase tracking-tight">
                  {p.name}
                </h3>
                {p.href && (
                  <ArrowUpRight
                    class="mt-1 h-5 w-5 shrink-0 text-muted transition group-hover:text-gold"
                    aria-hidden="true"
                  />
                )}
              </div>
              <p class="mt-2 max-w-sm text-sm leading-relaxed text-muted">
                {p.blurb}
              </p>
            </div>
          </Tag>
        );
      })
    }
  </div>

  <div class="mt-10">
    <WhatsAppButton label="3 занятия за 2990 ₸" />
  </div>
</section>
