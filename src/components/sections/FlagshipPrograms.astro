---
import { flagshipPrograms } from "../../data/programs";
import WhatsAppButton from "../ui/WhatsAppButton.astro";

// Map flagship slugs -> promo video files.
// TODO(content): drop the 4 Bronx promo videos into /public/video/ and confirm
//   mapping. STRETCH&GO has no promo clip yet -> uses poster only for now.
const videoBySlug: Record<string, string | undefined> = {
  "bronx-fire": "/video/fire.mp4",
  "bronx-fight": "/video/fight.mp4",
  "bronx-jlo": "/video/women.mp4", // женское промо
  "stretch-and-go": undefined, // TODO: short clip
};
---

<section id="flagships" class="mx-auto max-w-7xl px-6 py-16 md:py-24 lg:py-32">
  <p class="eyebrow">Самые любимые</p>
  <h2
    class="mt-3 text-3xl font-extrabold uppercase tracking-tight md:text-5xl"
  >
    С чего начинают
  </h2>
  <p class="mt-4 max-w-prose text-muted">
    Направления, куда приходит больше всего людей. Начни с любого — первые 3 занятия за 2990 ₸.
  </p>

  <div class="mt-10 grid gap-5 sm:grid-cols-2">
    {
      flagshipPrograms.map((p) => (
        <article class="group relative flex min-h-[22rem] flex-col justify-end overflow-hidden rounded border border-line">
          {/* Media */}
          {videoBySlug[p.slug] ? (
            <video
              class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-105"
              autoplay
              muted
              loop
              playsinline
            >
              <source src={videoBySlug[p.slug]} type="video/mp4" />
            </video>
          ) : (
            <div class="absolute inset-0 bg-surface">
              {/* TODO(content): image or short clip for STRETCH&GO */}
            </div>
          )}
          <div class="absolute inset-0 bg-gradient-to-t from-bg via-bg/50 to-transparent" />

          <div class="relative p-6">
            <h3 class="text-2xl font-extrabold uppercase tracking-tight">
              {p.name}
            </h3>
            <p class="mt-2 max-w-sm text-sm leading-relaxed text-muted">
              {p.blurb}
            </p>
          </div>
        </article>
      ))
    }
  </div>

  <div class="mt-10">
    <WhatsAppButton label="3 занятия за 2990 ₸" />
  </div>
</section>
